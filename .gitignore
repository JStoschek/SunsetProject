# CMake build artifacts
/build/
/build-debug/
/build-release/
cmake-build-*/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
CTestTestfile.cmake
Testing/
install_manifest.txt

# Compiled output
*.o
*.a
*.so
*.dylib

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editors
/.vscode/
.idea/
*.swp
*.swo
*~

# Local / private files
/.scratch/
/data/
/docs/
CLAUDE.md
CONTEXT.md
*.tif

# Generated tile pyramids (output of the tile encoder, issue 05)
/frontend/tiles/

# Vector basemap archive (~100 MB, regenerated via `pmtiles extract`; deploy
# straight to S3). The small vendored libs/fonts/sprite/theme ARE committed.
/frontend/basemap/*.pmtiles

# Node / JS tooling
/node_modules/

# Python build/cache artifacts (encode_tiles)
__pycache__/
*.pyc
*.egg-info/

# Profiling output
profile.json.gz
# captured Firefox profiler trace, not pipeline output (a gitignore pattern
# cannot carry a trailing comment — it becomes part of the pattern)
azimuth.json

# Local box manifest (template: boxes.example.json)
/boxes.json

# Local deploy config overrides sourced by scripts/deploy.sh — may hold
# environment-specific values; never commit it.
/scripts/deploy.env

# Derived from the local boxes.json by the run_boxes driver (fill_dir) —
# regenerated automatically, like the tile pyramid above.
/frontend/us_land_fill.geojson
